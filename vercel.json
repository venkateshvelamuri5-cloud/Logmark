{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/:encryptedProfileId/:assistantName",
      "destination": "/api/redirect?encryptedProfileId=:encryptedProfileId&assistantName=:assistantName"
    }
  ]
}
